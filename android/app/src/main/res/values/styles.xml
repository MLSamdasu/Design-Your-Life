<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        LaunchTheme: Android 프로세스 시작 시 즉시 표시되는 스플래시 테마
        Flutter 엔진이 첫 프레임을 그리기 전까지 이 테마가 보인다
        앱의 그라디언트 배경색(#667eea)과 매칭되는 흰색 배경으로 설정하여
        Flutter UI 로딩 전 빈 화면 깜빡임을 최소화한다
    -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- 스플래시 배경: launch_background drawable 참조 -->
        <item name="android:windowBackground">@drawable/launch_background</item>
        <!-- 상태 바 투명 처리로 몰입형 경험 제공 -->
        <item name="android:windowTranslucentStatus">true</item>
    </style>

    <!--
        NormalTheme: Flutter UI가 초기화된 후 적용되는 테마
        Flutter가 자체 렌더링을 제어하므로 배경색만 지정한다
        V2 Flutter Android 임베딩에서만 사용된다
    -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
